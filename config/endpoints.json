    },
    "REGION_LEVEL6": {
      "method": "GET",
      "path": "/app/api/region/api/v1/region/level6"
    },
    "REGION_LEVEL7": {
      "method": "GET",
      "path": "/app/api/region/api/v1/region/level7"
    },
    "REGION_LEVEL8": {
      "method": "GET",
      "path": "/app/api/region/api/v1/region/level8"
    },
    "REGION_LEVEL9": {
      "method": "GET",
      "path": "/app/api/region/api/v1/region/level9"
    },
    "REGION_LEVEL10": {
      "method": "GET",
      "path": "/app/api/region/api/v1/region/level10"
