{
  "BASE_URL": "https://fasih-sm.bps.go.id",
  "SSO_LOGOUT_URL": "https://sso.bps.go.id/auth/realms/pegawai-bps/protocol/openid-connect/logout",
  "DEPRECATED_ENDPOINTS": {
    "SAMPEL_DATATABLE_OLD": {
      "method": "POST",
      "path": "/allocations/samples/datatable"
    }
  },
