      "method": "POST",
      "path": "/logout"
    },
    "LIST_SURVEYS": {
      "method": "POST",
      "path": "/app/api/survey/api/v1/surveys/datatable",
      "default_payload": {
        "pageNumber": 0,
        "pageSize": 100,
        "sortBy": "CREATED_AT",
        "sortDirection": "DESC",
        "keywordSearch": ""
      }
    },
    "SURVEY_DETAIL": {
      "method": "GET",
      "path": "/app/api/survey/api/v1/surveys/{survey_id}"
    },
    "SURVEY_PERIODS": {
      "method": "GET",
      "path": "/app/api/survey/api/v1/survey-periods/my?surveyId={survey_id}"
