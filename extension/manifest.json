{
    "manifest_version": 3,
    "name": "FasihSM-Fetcher Session Sync",
    "version": "8.0",
    "description": "sesuai judul",
    "permissions": [
        "cookies",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "https://bps.go.id/*",
        "http://bps.go.id/*",
        "https://*.bps.go.id/*",
        "http://*.bps.go.id/*",
        "http://127.0.0.1:5000/*",
        "http://localhost:5000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Sync Session",
        "default_icon": "logo.png"
    },
    "icons": {
        "16": "logo.png",
        "48": "logo.png",
        "128": "logo.png"
    }
}